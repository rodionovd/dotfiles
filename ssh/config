Include ~/.ssh/1Password/config
Include ~/.orbstack/ssh/config

# 1Password as the default SSH agent
Host *
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

# Ghostty: even though I have set "shell-integration-features = ssh-env", it does
# not appear to work for `tailscale ssh`, thus this workaround
Host *
  SetEnv TERM=xterm-256color
